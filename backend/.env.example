# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# PostgreSQL (local)
PG_HOST=localhost
PG_PORT=5432
PG_DB=vitto_db
PG_USER=vitto_user
PG_PASSWORD=vitto_pass

# MongoDB (local)
MONGO_URI=mongodb://localhost:27017/vitto_mongo

# Redis (local)
REDIS_HOST=localhost
REDIS_PORT=6379

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
